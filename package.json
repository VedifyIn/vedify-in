{
  "name": "in.vedify",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,astro,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,json,md}\"",
    "check-types": "turbo run check-types",
    "check": "pnpm run format:check && pnpm run lint && pnpm run check-types",
    "fix": "pnpm run format && pnpm run lint -- --fix",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@vedify/eslint-config": "workspace:*",
    "typescript-eslint": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "turbo": "^2.9.18",
    "typescript": "5.9.2",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=26"
  }
}
