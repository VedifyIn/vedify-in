{
    "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/config-schema.json",
    "name": "vedify-in",
    "compatibility_date": "2026-06-27",
    "workers_dev": false,
    "preview_urls": false,
    "assets": {
        "directory": "./dist",
        "not_found_handling": "404-page"
    },
    "build": {
        "command": "pnpm --filter web astro build",
        "cwd": "../..",
        "watch_dir": [
            "src"
        ]
    },
    "env": {
        "develop": {
            "name": "vedify-in-develop",
            "assets": {
                "directory": "./dist"
            }
        }
    }
}