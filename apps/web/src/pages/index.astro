---
import '../globals.css';
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Coming Soon | Vedify.In</title>
  </head>
  <body class="m-0 flex min-h-screen items-center justify-center bg-[#0a0a0f]">
    <div
      class="fixed inset-0 pointer-events-none"
      style="background: radial-gradient(circle at 50% 50%, rgba(167, 139, 250, 0.08) 0%, transparent 50%)"
    >
    </div>
    <main class="flex flex-col items-center gap-6 px-4 text-center">
      <div class="om-symbol">🕉️</div>
      <p class="sanskrit">श्री गणेशाय नमः | जय चितई गोल्ज्यू</p>
      <p class="transliteration">Sree Ganeshay Namah | Jay Chitai Goljyu</p>
      <h1 class="coming-soon">Coming Soon</h1>
      <p class="subtitle">
        Something amazing is on the way. We're crafting an exceptional experience just for you.
      </p>
    </main>
  </body>
</html>
